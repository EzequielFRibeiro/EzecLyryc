# Database
DATABASE_URL=postgresql://cifrapartit:cifrapartit@localhost:5432/cifrapartit

# Redis
REDIS_URL=redis://localhost:6379/0

# S3-Compatible Storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=cifrapartit-audio

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (for verification and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@cifrapartit.com

# Application
ENVIRONMENT=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_UPLOAD_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,ogg,m4a,aac
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,webm

# Transcription Limits
FREE_TIER_MAX_DURATION_SECONDS=30
FREE_TIER_MAX_TRANSCRIPTIONS_PER_DAY=3
PRO_TIER_MAX_DURATION_SECONDS=900
YOUTUBE_MAX_DURATION_SECONDS=900
